@echo off
title BagBoard
set "SELF=%~f0"
set "PSF=%TEMP%\BagBoard.ps1"
powershell -NoProfile -ExecutionPolicy Bypass -Command "$s=[IO.File]::ReadAllText($env:SELF); $m='::BB'+'DATA::'; $b=($s -split $m)[1].Trim(); [IO.File]::WriteAllBytes($env:PSF,[Convert]::FromBase64String($b))"
powershell -NoProfile -ExecutionPolicy Bypass -File "%PSF%"
exit /b
